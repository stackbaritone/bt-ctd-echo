# Support Contact Configuration
# Email address for receiving support requests
VITE_SUPPORT_EMAIL=echo-info@bt-tb.ca

# Optional: Custom form submission endpoint (overrides Web3Forms)
# By default, the app uses Web3Forms with a built-in access key
# Example: VITE_SUPPORT_FORM_ENDPOINT=https://formspree.io/f/yourFormId
VITE_SUPPORT_FORM_ENDPOINT=
