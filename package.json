{
  "name": "echo-email-assistant",
  "private": false,
  "version": "1.0.0",
  "type": "module",
  "description": "ECHO Email Template Assistant - Professional email template management with rich text editing, AI assistance, and variable management",
  "homepage": "https://bt-ctd-echo.bt-tb.ca/",
  "repository": {
    "type": "git",
    "url": "https://github.com/snarky1980/bt-ctd-echo.git"
  },
  "scripts": {
    "dev": "vite",
    "dev:fixed": "vite",
    "start": "vite",
    "dev:clean": "node -e \"const {execSync}=require('node:child_process');try{const p=execSync('lsof -ti:5173',{stdio:['ignore','pipe','ignore']}).toString().trim();if(p) execSync('kill -9 '+p);}catch(e){}\" && npm exec vite",
    "dev:retry": "(npm exec vite -- --strictPort || npm exec vite -- --port 5174 --strictPort || npm exec vite -- --port 5175 --strictPort)",
    "build": "vite build",
    "preview": "vite preview",
    "serve:static": "npx http-server -p 5173 dist",
    "predeploy": "node scripts/sync/sync-templates.mjs",
    "deploy": "npm run build && npx --yes gh-pages -d dist --dotfiles",
    "templates:replace": "node scripts/utils/replace-templates.mjs",
    "convert:docx": "node scripts/convert/docx-to-templates.mjs",
    "merge:fr-en": "node scripts/utils/merge-fr-en.mjs",
    "convert:xlsx": "node scripts/convert/xlsx-to-templates.mjs",
    "convert:xlsx:variables": "node scripts/convert/xlsx-to-variables.mjs",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.13",
    "@radix-ui/react-label": "^2.1.6",
    "@radix-ui/react-scroll-area": "^1.2.8",
    "@radix-ui/react-select": "^2.2.4",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.1.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx": "^9.5.1",
    "dompurify": "^3.3.2",
    "file-saver": "^2.0.5",
    "fuse.js": "^7.0.0",
    "lucide-react": "^0.510.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^3.0.6",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "^4.1.7",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "cheerio": "^1.0.0-rc.12",
    "eslint": "^9.38.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "gh-pages": "^6.1.1",
    "globals": "^16.4.0",
    "jsdom": "^28.1.0",
    "mammoth": "^1.6.0",
    "vite": "^6.3.5",
    "vitest": "^4.0.18",
    "xlsx": "^0.18.5"
  }
}
